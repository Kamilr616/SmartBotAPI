@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://anstar.edu.pl" target="_blank" rel="noopener noreferrer">
                <img src="https://anstar.edu.pl/wp-content/themes/tarnowp/img/logo-akademia-nauk.svg" alt="Akademia Tarnowska" class="d-inline-block align-text-middle" style="max-height: 40px;">
            </a>

            <a href="https://github.com/Kamilr616/SmartBotAPI" target="_blank" rel="noopener noreferrer">
                <img src="GitHub_Logo.png" alt="GitHub" class="d-inline-block align-text-middle" style="max-height: 40px;">
            </a>
            
            <a href="https://dotnet.microsoft.com/" target="_blank" rel="noopener noreferrer" aria-label=".NET">
                <span style="font-size: 28px; font-weight: 700;">.NET</span>
            </a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
